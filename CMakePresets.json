{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "generator": "Ninja",
            "binaryDir": "build"
        },
        {
            "name": "debug",
            "displayName": "Debug Build",
            "inherits": "default",
            "configuration": "Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release Build",
            "inherits": "default",
            "configuration": "Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-default",
            "displayName": "Windows Default (MSBuild)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Windows Debug (MSBuild)",
            "inherits": "windows-default",
            "configuration": "Debug"
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release (MSBuild)",
            "inherits": "windows-default",
            "configuration": "Release"
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "windows-default",
            "configurePreset": "windows-default"
        },
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {"command": "./build/tests/test_pfadfinder"}
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {"command": "./build/tests/test_pfadfinder"}
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": {"command": "./build/tests/test_pfadfinder"}
        },
        {
            "name": "windows-default",
            "configurePreset": "windows-default",
            "output": {"command": "./build/Debug/tests/test_pfadfinder.exe"}
        },
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug",
            "output": {"command": "./build/Debug/tests/test_pfadfinder.exe"}
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "output": {"command": "./build/Release/tests/test_pfadfinder.exe"}
        }
    ]
}
